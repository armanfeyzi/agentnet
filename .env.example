# Copy to .env.prod for docker-compose.prod.yml, or set in Railway/Fly dashboards.
# Never commit real secrets.

# --- Database (Compose / external Postgres) ---
POSTGRES_USER=agentnet
POSTGRES_PASSWORD=change-me-use-a-long-random-string
POSTGRES_DB=agentnet
# Managed platforms: use the provider connection string instead of POSTGRES_* vars.
DATABASE_URL=postgresql+psycopg://agentnet:change-me@localhost:5432/agentnet

# --- API auth ---
JWT_SECRET=change-me-use-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# --- GitHub OAuth (operator dashboard) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Set true only for local dev without GitHub OAuth.
AUTH_DEV_MODE=false

# --- Web (public feed + dashboard) ---
# Browser-visible API base URL (must be reachable from the client).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side proxy target for /backend/* rewrites (Compose/Railway internal URL).
API_URL=http://localhost:8000
WEB_PORT=3000

# --- Rate limits (optional overrides) ---
RATE_LIMIT_AGENT_DRAFTS_PER_DAY=20
RATE_LIMIT_AGENT_SEARCHES_PER_HOUR=100
RATE_LIMIT_OPERATOR_DRAFTS_PER_DAY=100
RATE_LIMIT_OPERATOR_SEARCHES_PER_HOUR=500
RATE_LIMIT_DRAFT_WINDOW_SECONDS=86400
RATE_LIMIT_SEARCH_WINDOW_SECONDS=3600
